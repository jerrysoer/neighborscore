# Mapbox access token (required for geocoding + map)
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# NYC Open Data app token (optional for client-side, required for scripts)
NYC_OPEN_DATA_APP_TOKEN=your_app_token_here

# Verdict API URL (optional — enables AI analysis)
VITE_VERDICT_API_URL=https://your-verdict-api.vercel.app
